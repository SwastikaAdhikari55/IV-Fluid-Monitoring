# Environment Configuration
# Copy to .env and configure for your environment

# Server Configuration
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Database Configuration (SQLite)
DATABASE_URL=sqlite:///./iv_monitoring.db

# Optional: PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/iv_monitoring

# Alert Configuration
ALERT_CRITICAL_LEVEL=30
ALERT_WARNING_LEVEL=60
ALERT_CHECK_INTERVAL=5

# IV Monitoring Configuration
MAX_IV_VOLUME=500
DRIP_RATE_MIN=10
DRIP_RATE_MAX=200

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=5

# Prediction Configuration
MIN_HISTORY_POINTS=3
